        <text x="0" y="320" fill="white" font-size="19" text-anchor="middle">8pm</text><text x="100" y="320" fill="white" font-size="19" text-anchor="middle">12am</text><text x="200" y="320" fill="white" font-size="19" text-anchor="middle">4am</text><text x="300" y="320" fill="white" font-size="19" text-anchor="middle">8am</text><text x="400" y="320" fill="white" font-size="19" text-anchor="middle">12pm</text><text x="500" y="320" fill="white" font-size="19" text-anchor="middle">4pm</text><text x="600" y="320" fill="white" font-size="19" text-anchor="middle">8pm</text><line x1="100" y1="0" x2="100" y2="300" stroke="white" stroke-width="2" stroke-dasharray="3,3" />
